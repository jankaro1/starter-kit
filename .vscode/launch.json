{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start stk UI5 (Environment Enabled)",
      "type": "ui5",
      "request": "launch",
      "cwd": "${workspaceFolder}/stk",
      "config": {
        "target": {
          "open": "test/flp.html#app-preview"
        },
        "env": {
          "destinations": [],
          "services": []
        }
      }
    },
    {
      "name": "Start stk",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/stk",
      "runtimeExecutable": "npx",
      "windows": {
        "runtimeExecutable": "npx.cmd"
      },
      "runtimeArgs": [
        "fiori",
        "run"
      ],
      "args": [
        "--open",
        "test/flp.html#app-preview"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std",
      "env": {
        "DEBUG": "--inspect",
        "FIORI_TOOLS_URL_PARAMS": "sap-ui-xx-viewCache=false",
        "run.config": "{\"handlerId\":\"fiori_tools\",\"runnableId\":\"/home/user/projects/stk\"}"
      }
    },
    {
      "name": "Start stk Mock",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/stk",
      "runtimeExecutable": "npx",
      "windows": {
        "runtimeExecutable": "npx.cmd"
      },
      "runtimeArgs": [
        "fiori",
        "run"
      ],
      "args": [
        "--config",
        "./ui5-mock.yaml",
        "--open",
        "test/flp.html#app-preview"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std",
      "env": {
        "FIORI_TOOLS_URL_PARAMS": "sap-ui-xx-viewCache=false",
        "run.config": "{\"handlerId\":\"fiori_tools\",\"runnableId\":\"/home/user/projects/stk\"}"
      }
