{
  "_version": "1.60.0",
  "sap.app": {
    "id": "stk.stk",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.4",
      "toolsId": "cf282947-db69-42f3-bdf9-bdce14e11a34"
    },
    "dataSources": {
      "mainService": {
        "uri": "/V2/Northwind/Northwind.svc/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.120.43",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "rootView": {
      "viewName": "stk.stk.view.App",
      "type": "XML",
      "id": "app2",
      "async": true
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "stk.stk.i18n.i18n"
        }
      },
      "": {
        "type": "sap.ui.model.odata.v2.ODataModel",
        "dataSource": "mainService",
        "preload": false,
        "settings": {
          "defaultBindingMode": "TwoWay",
          "refreshAfterChange": false,
          "useBatch": false
        }
      },
      "CustomerProperties": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "type": "View",
        "viewType": "XML",
        "viewPath": "stk.stk.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true,
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "Default",
          "pattern": "",
          "target": "CustomerList"
        },
        {
          "name": "CustomerDetails",
          "pattern": "CustomerDetails/{CustomerID}",
          "target": "CustomerDetails"
        },
        {
          "name": "CreateCustomer",
          "pattern": "CreateCustomer",
          "target": "CreateCustomer"
        },
        {
          "name": "Performance",
          "pattern": "Performance",
          "target": "Performance"
        }
      ],
      "targets": {
        "CustomerList": {
          "viewName": "CustomerList"
        },
        "CustomerDetails": {
          "viewName": "CustomerDetails"
        },
        "CreateCustomer": {
          "viewName": "CreateCustomer"
        },
        "Performance": {
          "viewName": "Performance"
        }
      }
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "stkstk"
  }
}
